{
  "name": "your-project",
  "version": "1.0.0",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "build-and-dev": "vitepress build docs && vitepress dev docs",
    "deploy": "npm run build-and-push",
    "deploy-github": "npm run build-and-push",
    "build-and-deploy": "npm run build-and-push",
    "serve": "vitepress serve docs/.vitepress/dist",
    "build-and-push": "npm run build && git add . && (git diff --cached --quiet || git commit -m \"Auto-deploy: Built and pushed changes\") && git push origin main"
  },
  "devDependencies": {
    "postcss": "^8.5.6",
    "vitepress": "^1.5.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "basic-ftp": "^5.0.5",
    "ftp": "^0.3.10",
    "ssh2-sftp-client": "^12.0.1"
  }
}
